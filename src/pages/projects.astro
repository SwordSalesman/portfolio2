---
import Layout from "../layouts/Layout.astro";
import PortraitsBoard from "../components/portraits/PortraitsBoard.astro";
import WaystoneSection from "../components/waystone/WaystoneSection.astro";
import NavBar from "../components/NavBar.astro";
import UnderConstruction from "../components/UnderConstruction.astro";
import UFO from "../components/delights/UFO.astro";
---

<Layout title='Projects'>
	<NavBar title='projects' />
	<div id='projects-content'>
		<UFO />
		<WaystoneSection />
		<PortraitsBoard />
		<UnderConstruction />
	</div>
</Layout>

<style>
	#projects-content {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 60px;
		padding: 40px 0px 80px 0;
		margin: 0 auto;
		max-width: 780px;

		@media (max-width: 600px) {
			/* max-width: 94%; */
			overflow: hidden;
			gap: 75px;
		}
	}
</style>
