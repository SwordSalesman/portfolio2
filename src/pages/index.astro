---
import Layout from "../layouts/Layout.astro";
import VisitorPopup from "../components/VisitorPopup.astro";
import NavBar from "../components/NavBar.astro";
import GuestbookEntries from "../components/guestbook/GuestbookEntries.astro";
import BadgeBanner from "../components/BadgeBanner.astro";
import orb from "../assets/bits/orb.gif";
import Image from "astro/components/Image.astro";
import dragon from "../assets/bits/dragon.gif";
---

<Layout>
	<NavBar />
	<div class='container'>
		<div class='main-content'>
			<div class='header-container'>
				<h1>Welcome to Luke Cannon's Website!!!</h1>
				<p class='subheading'>[Random funny thing here]</p>
			</div>
			<div class='content-grid'>
				<div class='grid-col' id='grid-col-0'>
					<VisitorPopup count={42} />
					<div>
						<p class='gb-header'>Latest Guestbook Entries</p>
						<GuestbookEntries entryLimit={5} />
						<a href='/guestbook'>Sign the Guestbook!</a>
					</div>
					<!-- <Image src={dragon} alt='Dragon GIF' /> -->
				</div>
				<div class='grid-col' id='grid-col-1'>
					<div class='about-the-webmaster'>
						<h2>About the Webmaster</h2>
						<p>
							Hi!!! I'm Luke. My job is computer. I hope you enjoy
							this website, because I enjoyed making it. Why don't
							you stay a while and look around?
						</p>
						<p>Check out my <a href='/projects'>projects</a>!</p>
						<p>Sign the <a href='/guestbook'>guestbook</a>!</p>
						<p>Get in touch <a href='/contact'>here</a>!</p>
					</div>
					<a
						href='https://www.youtube.com/watch?v=xOPVMhbhfDE'
						target='_blank'
						rel='noopener noreferrer'
						class='orb-ad'
					>
						<Image src={orb} alt='Enlarge your orb fake ad' />
					</a>
					<BadgeBanner />
				</div>
			</div>
		</div>
	</div>
</Layout>

<style>
	.container {
		margin-bottom: 40px;
	}
	.content {
		/* padding: 24px; */
	}

	h2 {
		margin: 0;
		font-family: cursive, sans-serif;
	}
	.subheading {
		/* font-size: 1.25rem; */
		color: var(--color-lime);
		font-style: italic;
	}
	.main-content {
		padding: 10px;
		max-width: var(--max-width-page);
		margin: 0 auto;
	}

	.content-grid {
		display: grid;
		grid-template-columns: 1fr 2fr;
		gap: 12px;

		@media (max-width: 600px) {
			grid-template-columns: 1fr;
		}
	}

	.grid-col {
		display: flex;
		flex-direction: column;
		gap: 12px;
		/* padding: 6px; */
	}

	#grid-col-1 {
		/* background: rgb(209, 208, 221); */
		/* background: rgb(230, 190, 233); */
	}

	.gb-header {
		margin: 0;
		font-family: "Comic Sans MS", cursive, sans-serif;
		color: var(--color-pink);
	}

	.header-container {
		text-align: center;
		margin-bottom: 24px;
	}

	.header-container h1,
	.header-container p {
		margin: 10px 0;
	}

	.about-the-webmaster {
		padding: 12px;
		background: rgb(34, 33, 64);
		border: 2px solid var(--color-pink);
	}
	.orb-ad {
		margin: 0 auto;
		height: auto;
		border: 2px solid rgba(255, 255, 255, 0.433);

		@media (max-width: 600px) {
		}
	}

	.orb-ad img {
		display: block;
		width: 100%;
		height: auto;
	}
</style>
