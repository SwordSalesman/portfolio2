---
import pinImg from "../../assets/bits/pin.png";

const hueRotation = Math.floor(Math.random() * 3) * 120;
const rotation = Math.floor(Math.random() * 60) - 30;
---

<img
	src={pinImg.src}
	class='pin'
	style={`filter: hue-rotate(${hueRotation}deg); transform: rotate(${rotation}deg) translateX(-50%);`}
	alt=''
	aria-hidden='true'
/>

<style>
	.pin {
		position: absolute;
		top: -14px;
		left: 50%;
		width: 36px;
		height: auto;
		z-index: 2;
		pointer-events: none;
		filter: drop-shadow(5px 12px 12px rgba(0, 0, 0, 0.5));
	}
</style>
