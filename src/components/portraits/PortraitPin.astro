---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import Pin from "./Pin.astro";

interface Props {
	image: ImageMetadata;
	alt: string;
}

const { image, alt } = Astro.props;
---

<div class='portrait-pin'>
	<Pin />
	<div class='print'>
		<Image src={image} alt={alt} width={180} />
	</div>
</div>

<style>
	.portrait-pin {
		width: fit-content;
		position: relative;
	}

	.print {
		background: white;
		padding: 10px 10px;
		pointer-events: none;
	}

	.print img {
		display: block;
		width: 200px;
		height: auto;

		@media (max-width: 600px) {
			width: 150px;
		}
	}
</style>
