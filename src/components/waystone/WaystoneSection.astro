---
import { Image } from "astro:assets";
import demo from "../../assets/waystone/waystone-demo.gif";
import star from "../../assets/bits/star.gif";
import cursorClick from "../../assets/bits/cursor-click.gif";
import loading from "../../assets/bits/loading.gif";
---

<section class='waystone-page'>
	<!-- Header -->
	<div class='ws-header ws-section--lg'>
		<span class='ws-new-badge'>★ NEW!</span>
		<div class='ws-title-row'>
			<Image src={star} alt='' class='ws-title-star' />
			<h2 class='ws-title'>
				WAYSTONE<span style='font-weight: normal;'>™* </span>
				<span class='ws-version'>v2.0</span>
			</h2>
		</div>
		<p class='ws-tagline'>"The Portal For Concordian Heroes"</p>
		<div class='ws-rating'>★★★★★ &nbsp;|&nbsp; Downloaded 0 times</div>
	</div>

	<!-- Screenshots -->
	<div class='ws-screenshots ws-section'>
		<div class='ws-screenshot-frame'>
			<Image src={demo} alt='Waystone demo - character creation' />
			<p class='ws-caption'>Interactively create your character!</p>
		</div>
		<div class='ws-screenshot-frame'>
			<Image src={demo} alt='Waystone demo - character sheet' />
			<p class='ws-caption'>Admins can view and approve submissions!</p>
		</div>
	</div>

	<!-- Features + CTA -->
	<div class='ws-middle ws-section'>
		<ul class='ws-features'>
			<li>✔ Build your Concord Larp character in minutes!</li>
			<li>✔ Written with React, Next.js, Tailwind, and other stuff!</li>
			<li>✔ FREE for the first 1,000,000 users!!!</li>
			<li>✔ Owned and managed by the famous <i>Concord Web Team</i></li>
			<li>✔ No ads (yet), user data is competely safe (currently)</li>
		</ul>
		<div class='ws-cta'>
			<a
				href='https://waystone.concordlarp.com'
				target='_blank'
				rel='noopener noreferrer'
				class='ws-btn-primary'>LAUNCH APP NOW →</a
			>
			<a
				href='https://waystone.concordlarp.com'
				target='_blank'
				rel='noopener noreferrer'
				class='ws-btn-secondary'>Also available: FREE</a
			>
		</div>
	</div>

	<!-- Awards -->
	<div class='ws-awards ws-section'>
		<p class='ws-section-title'>AWARDS & RECOGNITION</p>
		<p class='ws-awards-text'>
			{"<NO DATA FOUND. CHECK INTERNET CONNECTION>"}
		</p>
	</div>

	<!-- System Requirements -->
	<div class='ws-sysreq ws-section'>
		<p class='ws-section-title'>SYSTEM REQUIREMENTS</p>
		<table>
			<tr><td>OS</td><td>Any</td></tr>
			<tr
				><td>RAM</td><td
					><Image src={loading} alt='' class='ws-loading' /></td
				></tr
			>
			<tr
				><td>Storage</td><td
					>{"<"}1MB for the base version. 127GB for premium.</td
				></tr
			>
			<tr><td>Requires</td><td>Dial up internet connection</td></tr>
		</table>
		<p class='ws-disclaimer'>
			*Waystone is not trademarked. The ™ symbol is there because I can't
			figure out how to get rid of it. If anyone can help me with this,
			please leave a message in the <a href='/guestbook'>guestbook</a> or <a
				href='/contact'>contact me</a
			>.
		</p>
	</div>

	<!-- Download -->
	<div class='ws-download-section ws-section'>
		<Image src={cursorClick} alt='' class='ws-download-cursor' />
		<div class='ws-download-chain'>
			{
				[...Array(5)].map(() => (
					<a
						href='https://waystone.concordlarp.com'
						target='_blank'
						rel='noopener noreferrer'
						class='big-download-button'
					>
						<p>Download NOW!</p>
					</a>
				))
			}
		</div>
	</div>
</section>

<style>
	/* ── Shared section utilities ── */
	.ws-section {
		padding: 16px 24px;
		border-top: 2px solid #808080;

		@media (max-width: 600px) {
			padding: 20px 16px;
		}
	}

	.ws-section--lg {
		padding: 20px 24px;

		@media (max-width: 600px) {
			padding: 24px 16px;
		}
	}

	.ws-section-title {
		font-weight: bold;
		font-size: 11px;
		text-transform: uppercase;
		letter-spacing: 1px;
		margin: 0 0 10px;
	}

	/* ── Page shell ── */
	.waystone-page {
		background: #d4d0c8;
		color: #000;
		font-size: 13px;
		border: 2px solid #808080;
		display: flex;
		flex-direction: column;
		width: 100%;
	}

	/* ── Header ── */
	.ws-header {
		background: linear-gradient(90deg, #000080, #370ebf);
		color: white;
	}

	.ws-new-badge {
		background: #ffff00;
		color: #000;
		font-weight: bold;
		font-size: 11px;
		padding: 2px 6px;
		margin-bottom: 6px;
		display: inline-block;
	}

	.ws-title-row {
		display: flex;
		align-items: center;
		gap: 6px;
	}

	.ws-title {
		font-size: 2rem;
		margin: 4px 0;
		font-family: "Comic Sans MS", cursive;
		color: #fff;
	}

	.ws-version {
		font-size: 1rem;
		opacity: 0.7;
	}

	.ws-tagline {
		font-style: italic;
		margin: 4px 0;
		opacity: 0.85;
	}

	.ws-rating {
		margin-top: 6px;
		font-size: 12px;
		opacity: 0.75;
	}

	/* ── Screenshots ── */
	.ws-screenshots {
		display: flex;
		gap: 16px;
		flex-wrap: wrap;
		background: #fff;
	}

	.ws-screenshot-frame {
		flex: 1 1 240px;
		border: inset 3px;
		background: #000;
		text-align: center;
	}

	.ws-screenshot-frame img {
		display: block;
		width: 100%;
		height: auto;
	}

	.ws-caption {
		color: #ccc;
		font-size: 11px;
		margin: 4px 0;
	}

	/* ── Features + CTA ── */
	.ws-middle {
		display: flex;
		gap: 24px;
		align-items: flex-start;
		flex-wrap: wrap;
	}

	.ws-features {
		flex: 1 1 200px;
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.ws-cta {
		margin: auto;
		display: flex;
		flex-direction: column;
		gap: 8px;
		min-width: 180px;
	}

	.ws-btn-primary {
		display: block;
		background: #000080;
		color: #fff;
		text-align: center;
		padding: 10px 16px;
		font-weight: bold;
		font-size: 13px;
		text-decoration: none;
		border: outset 2px;
	}

	.ws-btn-primary:hover {
		background: #0000aa;
	}

	.ws-btn-secondary {
		display: block;
		text-align: center;
		padding: 6px 16px;
		font-size: 11px;
		color: #000080;
		text-decoration: underline;
		border: outset 2px;
		background: #d4d0c8;
	}

	/* ── Awards ── */
	.ws-awards {
		background: #ececec;
	}

	.ws-awards-row {
		display: flex;
		gap: 12px;
		flex-wrap: wrap;
	}

	.ws-awards-text {
		font-size: 12px;
		margin: 0;
		color: #555;
	}

	.ws-award-badge {
		border: 2px solid #808080;
		background: #fff;
		padding: 6px 10px;
		font-size: 11px;
		text-align: center;
		line-height: 1.4;
	}

	/* ── System Requirements ── */
	.ws-loading {
		width: 14px;
		height: 14px;
	}

	.ws-sysreq table {
		border-collapse: collapse;
		width: 100%;
	}

	.ws-sysreq td {
		padding: 2px 4px;
		border-bottom: 1px solid #ccc;
		vertical-align: top;
	}

	.ws-sysreq td:first-child {
		font-weight: bold;
		white-space: nowrap;
		width: 100px;
	}

	.ws-disclaimer {
		font-size: 10px;
		color: #555;
		margin-top: 12px;
	}

	.ws-disclaimer a {
		color: #1900ff;
		text-decoration: underline;
	}

	/* ── Download ── */
	.ws-download-section {
		overflow: hidden;
		background: #fff;
		position: relative;
	}

	.ws-download-chain {
		display: flex;
		position: relative;
		left: -60px;
	}

	.ws-download-chain a {
		flex-shrink: 0;
		margin-right: 15px;
		animation: scroll-left 3s linear infinite;
	}

	.big-download-button {
		background: linear-gradient(to bottom, #075903, #15a90e);
		border-radius: 8px;
		width: 215px;
	}

	.big-download-button p {
		font-size: 18px;
		padding: 12px 24px;
		margin: 0;
		font-weight: bold;
		text-align: center;
		color: #fff;
		text-decoration: underline;
	}

	.ws-download-cursor {
		height: 28px;
		width: 28px;
		position: absolute;
		z-index: 2;
		top: 32px;
		right: 20px;
	}

	@keyframes scroll-left {
		0% {
			transform: translateX(0);
		}
		100% {
			transform: translateX(-230px);
		}
	}
</style>
