---
import waystoneDemo from "../../assets/waystone/waystone-demo.gif";
---

<section class='career-timeline'>
	<div class='career-row'>
		<div class='career-gif'>
			<img src={waystoneDemo.src} alt='Job placeholder' />
		</div>
		<div class='career-info'>
			<h2>Job Title One</h2>
			<p class='career-company'>Company Name · 2022 – Present</p>
			<p class='career-desc'>
				Lorem ipsum dolor sit amet, consectetur adipiscing elit.
				Placeholder description for this role goes here.
			</p>
		</div>
	</div>

	<div class='career-divider'></div>
</section>

<style>
	.career-timeline {
		display: flex;
		flex-direction: column;
		gap: 0;
		width: 100%;
		/* background: rgb(8, 8, 8); */
		padding: 10px;
	}

	.career-row {
		display: grid;
		grid-template-columns: 160px 1fr;
		gap: 24px;
		align-items: start;
		padding: 24px 0;
	}

	.career-gif img {
		width: 100%;
		image-rendering: pixelated;
	}

	.career-info h2 {
		font-family: "Comic Sans MS", cursive, sans-serif;
		font-size: 1.4rem;
		margin: 0 0 4px;
		color: var(--color-cyan);
	}

	.career-company {
		font-size: 12px;
		color: var(--color-pink);
		margin: 0 0 10px;
	}

	.career-desc {
		font-family: var(--font-body);
		font-size: 13px;
		color: var(--color-text);
		line-height: 1.6;
		margin: 0;
	}

	.career-divider {
		border: none;
		border-top: 1px dashed #444;
		margin: 0;
	}

	@media (max-width: 540px) {
		.career-row {
			grid-template-columns: 1fr;
		}

		.career-gif img {
			width: 120px;
		}
	}
</style>
