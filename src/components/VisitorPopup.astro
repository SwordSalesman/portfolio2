---
import Image from "astro/components/Image.astro";
import skeleton from "../assets/bits/skeleton.gif";
---

<div class='window visitor-popup'>
	<div class='title-bar'>
		<div class='title-bar-text'>Welcome!</div>
		<div class='title-bar-controls'>
			<button
				aria-label='Minimize'
				onclick="this.closest('.visitor-popup').querySelector('.window-body').classList.toggle('hidden')"
			></button>
			<button aria-label='Maximize'></button>
			<button
				aria-label='Close'
				onclick="this.closest('.visitor-popup').style.display='none'"
			></button>
		</div>
	</div>
	<div class='window-body'>
		<!-- <Image src={skeleton} alt='Skeleton GIF' style='margin-bottom: 12px' /> -->
		<p>You are visitor number:</p>
		<div class='counter'>00000042</div>
		<p class='thankyou'>Thanks for stopping by!!! :)</p>
		<section class='field-row' style='justify-content: flex-end'>
			<button
				onclick="
				this.closest('.window-body').querySelector('.thankyou').textContent.includes('OKAY')
				? this.closest('.window-body').querySelector('.thankyou').textContent += ' OKAY!'
					: this.closest('.window-body').querySelector('.thankyou').textContent = 'OKAY!'
				"
				>OK</button
			>
		</section>
	</div>
</div>

<script>
	import { doc, getDoc, setDoc } from "firebase/firestore";
	import { db } from "../utils/firebase";

	const counter = document.querySelector(".visitor-popup .counter");
	const LAST_VISIT_KEY = "visitorPopupLastVisit";
	const lastVisit = localStorage.getItem(LAST_VISIT_KEY) || "0";
	const lastVisitMs = parseInt(lastVisit);
	const now = Date.now();
	const ONE_HOUR_MS = 1 * 60 * 60 * 1000;

	/*
	Visitor count logic:
	- Fetch the current count from Firestore and display it.
	- If the user hasn't visited in the last hour, update their last visit time in localStorage, then incremenet the firestore count
	*/

	async function updateUserCount() {
		try {
			// Fetch user count from firestore
			const docRef = doc(db, "public", "userCount");
			const docSnap = await getDoc(docRef);
			var count = 0;
			if (docSnap.exists()) {
				count = docSnap.data()?.count || 42;
			}

			// Check if we should update the count based on last visit time
			var shouldIncrement = false;
			if (now - lastVisitMs > ONE_HOUR_MS) {
				shouldIncrement = true;
			}

			// Update the displayed count, incrementing if needed
			const currentCount = shouldIncrement ? count + 1 : count;
			const padded = String(currentCount).padStart(8, "0");
			if (counter) counter.textContent = padded;

			// Send increment to firestore if needed
			if (shouldIncrement) {
				localStorage.setItem(LAST_VISIT_KEY, now.toString());
				await setDoc(doc(db, "public", "userCount"), {
					count: currentCount,
				});
			}
		} catch (error) {
			console.error("Error with user count:", error);
			if (counter) counter.textContent = "00xERROR";
		}
	}

	updateUserCount();
</script>

<style>
	.visitor-popup {
	}

	.visitor-popup:active {
	}

	.visitor-popup {
		color: black;
	}

	.window-body {
		padding: 8px;
		text-align: center;
	}

	.window-body p {
		margin: 0 0 10px;
		cursor: default !important;
		font-size: 1rem;
	}

	.window-body.hidden {
		display: none;
	}

	.counter {
		font-family: "Courier New", Courier, monospace;
		font-size: 28px;
		font-weight: bold;
		background: black;
		color: #00ff41;
		letter-spacing: 3px;
		padding: 4px 10px;
		display: inline-block;
		border: inset 2px;
		margin-bottom: 12px;
	}

	.thankyou {
		/* color: #444; */
	}

	.field-row {
		margin-top: 12px;
	}
</style>
