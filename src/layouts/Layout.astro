---
import UFO from "../components/delights/UFO.astro";
import "98.css";
import "../styles/tokens.css";

interface Props {
	title?: string;
}
const { title } = Astro.props;
const pageTitle = title ? `${title} | Luke Cannon` : "Luke Cannon";
---

<!doctype html>
<html lang='en'>
	<head>
		<meta charset='UTF-8' />
		<meta name='viewport' content='width=device-width' />
		<link rel='icon' href='/favicon.ico' />
		<meta name='generator' content={Astro.generator} />
		<title>{pageTitle}</title>
	</head>
	<body>
		<main>
			<UFO />
			<slot />
		</main>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		padding: 0;
		min-height: 100%;

		/* Use stars.jpg from /assets */
		background-color: var(--color-bg);
		background-image: url("../assets/stars copy.jpg");
		background-size: 350px 350px;

		color: var(--color-text);
		font-family: var(--font-body);
		font-size: var(--font-size-base);
	}

	/* 98.css ships its own body font — override it back to ours */
	body {
		font-family: var(--font-body);
	}

	main {
		max-width: 960px;
		margin: 0 auto;
		/* padding: 16px 16px; */
	}
</style>
